    ]
  },

  "qualityGate": {
    "requiredBeforeRelease": true,

    "checks": [
      "all-nine-token-files-present",
      "all-json-valid",
      "all-required-fields-present",
      "dependencies-valid",
      "no-circular-dependencies",
      "paths-valid",
      "themes-resolvable",
      "accessibility-reviewed",
      "cultural-review-completed",
      "version-updated",
      "changelog-updated"
    ]
  },

  "automationReady": {
    "jsonValidation": true,
    "dependencyValidation": true,
    "fileExistenceValidation": true,
    "cssGeneration": "planned",
    "themeLoaderGeneration": "planned",
    "contrastTesting": "planned",
    "assetIntegrityHashing": "planned",
    "continuousIntegration": "future"
  },

  "plannedOutputs": {
    "css": {
      "path": "assets/brand/tokens/tokens.css",
      "purpose": "Converter tokens aprovados em variáveis CSS utilizáveis diretamente pelas interfaces."
    },

    "themeLoader": {
      "path": "assets/brand/tokens/theme-loader.js",
      "purpose": "Controlar seleção, persistência e aplicação dinâmica dos temas."
    },

    "generatedDocumentation": {
      "path": "assets/brand/tokens/README.md",
      "purpose": "Documentar consumo técnico e arquitetura dos Design Tokens."
    }
  },

  "restrictions": [
    "Não excluir um token set obrigatório sem aprovação institucional.",
    "Não alterar ordem de dependência sem revisão técnica.",
    "Não criar dependências circulares.",
    "Não apontar para arquivos inexistentes.",
    "Não utilizar arquivos gerados como fonte primária de verdade.",
    "Não duplicar tokens para resolver problemas locais sem revisão.",
    "Não remover suporte de acessibilidade.",
    "Não alterar significado cultural de símbolos ou ícones.",
    "Não publicar mudanças estruturais sem atualizar versão.",
    "Toda alteração deve ser registrada no CHANGELOG.md."
  ],

  "validationCommands": {
    "validateIndex": "python -m json.tool assets/brand/tokens/index.json > /dev/null",

    "validateAllJson": "for f in assets/brand/tokens/*.json; do python -m json.tool \"$f\" > /dev/null || exit 1; done",

    "listTokenFiles": "find assets/brand/tokens -maxdepth 1 -type f -print",

    "expectedCount": 10
  },

  "futureEvolution": {
    "recommended": [
      "Gerar tokens.css automaticamente.",
      "Gerar theme-loader.js.",
      "Criar README técnico da pasta tokens.",
      "Criar validador automático de dependências.",
      "Criar verificação automática de arquivos referenciados.",
      "Criar testes de contraste WCAG.",
      "Criar geração automática de documentação.",
      "Criar integração CI/CD.",
      "Gerar hashes de integridade.",
      "Preparar migração versionada para FESTANÇA 2027."
    ]
  },

  "nextRecommendedFiles": [
