  "sourceOfTruth": {
    "strategy": "single-source-of-truth",

    "rules": [
      "Tokens devem ser alterados primeiro em seus arquivos JSON oficiais.",
      "CSS gerado não deve substituir os arquivos JSON como fonte primária.",
      "JavaScript deve consumir ou refletir os tokens oficiais.",
      "Temas devem referenciar tokens existentes.",
      "Não duplicar valores sem justificativa técnica.",
      "Mudanças devem ser versionadas.",
      "Toda alteração oficial deve constar no CHANGELOG.md."
    ]
  },

  "namingConvention": {
    "tokenSetFile": "lowercase-plural.json",

    "examples": [
      "colors.json",
      "typography.json",
      "spacing.json",
      "radius.json",
      "shadows.json",
      "animations.json",
      "icons.json",
      "symbols.json",
      "themes.json"
    ],

    "tokenPattern": "{domain}.{category}.{name}",

    "cssVariablePattern": "--festanca-{domain}-{category}-{name}",

    "rules": [
      "Usar nomenclatura semântica.",
      "Evitar nomes baseados apenas na aparência.",
      "Não utilizar números mágicos como nomes.",
      "Preservar compatibilidade entre versões."
    ]
  },

  "governance": {
    "projectCurator": "Antonio Décio Ferreira Coelho",

    "institutionalCustodian": "Ecossistema Décio Coelho Global",

    "communityReference": "Comunidade de Vila Bela da Santíssima Trindade",

    "technologyPartners": [
      "OpenAI",
      "ChatGPT"
    ],

    "approvalRequiredFor": [
      "new-token-set",
      "breaking-change",
      "theme-removal",
      "cultural-symbol-change",
      "naming-change",
      "accessibility-regression",
      "license-change"
