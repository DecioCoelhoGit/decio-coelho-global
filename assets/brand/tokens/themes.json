  "themeSwitching": {
    "supported": true,

    "htmlAttribute": "data-theme",

    "examples": [
      "data-theme=\"dark\"",
      "data-theme=\"light\"",
      "data-theme=\"heritage\"",
      "data-theme=\"ceremonial\"",
      "data-theme=\"high-contrast\"",
      "data-theme=\"holographic\""
    ],

    "storage": {
      "strategy": "localStorage",
      "key": "festanca-theme"
    },

    "systemPreference": {
      "supported": true,
      "darkQuery": "(prefers-color-scheme: dark)",
      "lightQuery": "(prefers-color-scheme: light)"
    },

    "priority": [
      "explicit-user-selection",
      "stored-preference",
      "system-preference",
      "default-theme"
    ]
  },

  "accessibility": {
    "globalRules": [
      "Todos os temas devem preservar foco visível.",
      "Tema high-contrast deve estar sempre disponível.",
      "Nenhum tema pode depender apenas de cor para transmitir estado.",
      "Textos devem respeitar contraste mínimo adequado.",
      "Movimento reduzido deve funcionar em todos os temas.",
      "Tamanhos mínimos de toque devem ser preservados.",
      "Temas decorativos não podem comprometer leitura."
    ],

    "highContrastFallback": "high-contrast",

    "reducedMotion": {
      "respectSystemPreference": true,
      "reference": "assets/brand/tokens/animations.json"
    }
  },

  "responsiveBehavior": {
    "mobile": {
      "reduceOrnamentDensity": true,
      "reduceHolographicEffects": true,
      "minimumTouchTarget": "44px"
    },

    "tablet": {
      "reduceOrnamentDensity": "optional"
    },

    "desktop": {
      "fullThemeExpression": true
    },

    "largeDisplay": {
      "monumentalEffectsAllowed": true,
      "enhancedCeremonialComposition": true
    }
  },

  "performance": {
    "rules": [
      "Não carregar assets específicos de temas não utilizados quando evitável.",
      "Preferir CSS variables para alternância.",
      "Evitar reprocessamento completo de layout na troca de tema.",
      "Carregar efeitos holográficos sob demanda.",
      "Não duplicar imagens apenas para alteração simples de cor.",
      "Preferir SVG para futuras variantes vetoriais."
    ]
  },

  "cssContract": {
    "rootSelector": ":root",

    "themeSelectorPattern": "[data-theme=\"{theme}\"]",

    "coreVariables": [
      "--festanca-bg",
      "--festanca-bg-secondary",
      "--festanca-surface",
      "--festanca-surface-elevated",
      "--festanca-text",
      "--festanca-text-secondary",
      "--festanca-text-muted",
      "--festanca-primary",
      "--festanca-primary-strong",
      "--festanca-secondary",
      "--festanca-accent",
      "--festanca-border",
      "--festanca-focus",
      "--festanca-success",
      "--festanca-warning",
      "--festanca-error",
      "--festanca-info"
    ]
