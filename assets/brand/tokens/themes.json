    "version": "1.0.0",
    "status": "official",
    "language": "pt-BR",
    "createdAt": "2026-07-18",
    "updatedAt": "2026-07-18",

    "repositoryPath": "assets/brand/tokens/themes.json",

    "colorsReference": "assets/brand/tokens/colors.json",
