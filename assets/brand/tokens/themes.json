  "purpose": {
    "description": "Compor os tokens fundamentais do Brand Design System da FESTANÇA 2026 em temas completos, coerentes e reutilizáveis para interfaces, páginas, documentos, painéis, aplicações culturais e experiências digitais.",

    "objectives": [
      "Centralizar decisões visuais por contexto.",
      "Evitar estilização arbitrária.",
      "Permitir alternância consistente entre temas.",
      "Garantir acessibilidade.",
      "Preservar identidade cultural.",
      "Facilitar implementação em CSS, JavaScript e frameworks.",
      "Preparar o sistema para futuras edições da FESTANÇA."
    ]
  },

  "principles": {
    "rules": [
      "Todo tema deve herdar os tokens fundamentais oficiais.",
      "Temas não podem redefinir arbitrariamente identidade institucional.",
      "Acessibilidade prevalece sobre efeitos decorativos.",
      "Tema ceremonial deve preservar sobriedade e solenidade.",
      "Tema heritage deve priorizar memória e leitura.",
      "Tema holographic deve permanecer opcional.",
      "Tema high-contrast deve priorizar legibilidade máxima.",
      "Nenhum tema deve comprometer conteúdo cultural ou religioso.",
      "Alterações estruturais devem ser registradas no CHANGELOG.md."
    ]
  },

  "themeOrder": [
    "dark",
    "light",
    "heritage",
    "ceremonial",
    "high-contrast",
    "holographic"
  ],

  "defaultTheme": "dark",

