  "accessibility": {
    "rules": [
      "Não utilizar cor como único meio de transmitir informação.",
      "Verificar contraste entre texto e fundo antes da publicação.",
      "Utilizar texto claro sobre fundos azul profundo, preto ou patrimonial.",
      "Utilizar texto escuro sobre fundos marfim, branco ou dourado claro.",
      "Manter foco visível em elementos interativos.",
      "Evitar dourado claro como texto pequeno sobre fundo branco.",
      "Associar estados de sucesso, aviso e erro a ícones ou mensagens textuais."
    ],

    "recommendedMinimumContrast": {
      "normalText": "4.5:1",
      "largeText": "3:1",
      "interfaceElements": "3:1"
    }
  },

  "restrictions": [
    "Não criar novas cores institucionais sem revisão.",
    "Não substituir tokens oficiais diretamente em componentes isolados.",
    "Não usar tons culturais para representar outro grupo sem validação.",
    "Não utilizar o vermelho como cor dominante fora de contexto aprovado.",
    "Não utilizar o dourado em excesso a ponto de prejudicar a leitura.",
    "Toda alteração deve ser registrada no CHANGELOG.md."
  ],

