{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "tokenSetType": "festanca-symbol-design-tokens",

  "project": {
    "id": "festanca-2026",
    "name": "FESTANÇA 2026",
    "location": "Vila Bela da Santíssima Trindade - Mato Grosso - Brasil",
    "tagline": "Ao encontro do futuro, com os pés firmes na tradição."
  },

  "metadata": {
    "version": "1.0.0",
    "status": "official",
    "language": "pt-BR",
    "createdAt": "2026-07-18",
    "updatedAt": "2026-07-18",

    "repositoryPath": "assets/brand/tokens/symbols.json",
    "symbolsDirectory": "assets/brand/symbols/",

    "manifestReference": "assets/brand/brand-manifest.json",
    "catalogReference": "assets/brand/brand-assets-catalog.json",

    "colorTokensReference": "assets/brand/tokens/colors.json",
    "typographyTokensReference": "assets/brand/tokens/typography.json",
    "spacingTokensReference": "assets/brand/tokens/spacing.json",
    "radiusTokensReference": "assets/brand/tokens/radius.json",
    "shadowTokensReference": "assets/brand/tokens/shadows.json",
    "animationTokensReference": "assets/brand/tokens/animations.json",
    "iconTokensReference": "assets/brand/tokens/icons.json",

    "usageGuideReference": "assets/brand/USAGE-GUIDE.md",
    "licenseReference": "assets/brand/LICENSE-AND-CREDITS.md",
    "governanceReference": "assets/brand/governance.md",
    "qualityChecklistReference": "assets/brand/quality-checklist.md"
  },

  "namingConvention": {
    "fileFormat": "nome-descritivo.ext",
    "tokenFormat": "symbol.{category}.{name}",
    "cssVariableFormat": "--festanca-symbol-{property}",

    "examples": [
      "symbol.primary.star",
      "symbol.primary.goldenArc",
      "symbol.decorative.ornaments",
      "symbol.structural.frames",
      "symbol.graphic.elements"
    ],

    "rules": [
      "Utilizar nomes descritivos em português sem acentos no arquivo.",
      "Utilizar letras minúsculas.",
      "Separar palavras por hífen.",
      "Manter um identificador único por símbolo.",
      "Não reutilizar o mesmo arquivo com significados conflitantes.",
      "Registrar alterações no CHANGELOG.md."
    ]
  },

  "principles": {
    "description": "Os símbolos oficiais da FESTANÇA 2026 formam uma gramática visual própria destinada a comunicar luz, continuidade, tradição, proteção, solenidade, território e identidade.",

    "rules": [
      "O símbolo deve preservar seu significado institucional.",
      "Elementos estruturais não devem ser usados como mera decoração aleatória.",
      "Símbolos derivados da marca devem manter coerência com o logotipo oficial.",
      "O significado cultural deve prevalecer sobre efeitos estéticos.",
      "A ornamentação deve reforçar, e não competir com, o conteúdo.",
      "Aplicações litúrgicas ou tradicionais exigem maior sobriedade.",
      "As composições devem respeitar áreas de proteção.",
      "A proporcionalidade original deve ser mantida."
    ]
  },

  "categories": {
    "primary": {
      "label": "Símbolos primários",
      "description": "Elementos diretamente associados à identidade central da FESTANÇA."
    },

    "decorative": {
      "label": "Elementos ornamentais",
      "description": "Recursos de apoio visual para composição."
    },

    "structural": {
      "label": "Elementos estruturais",
      "description": "Molduras e estruturas de organização visual."
    },

    "graphic": {
      "label": "Elementos gráficos",
      "description": "Conjunto de componentes complementares do sistema visual."
    }
  },

