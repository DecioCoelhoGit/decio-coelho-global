  "symbolHierarchy": {
    "level1": {
      "name": "Identidade Primária",
      "symbols": [
        "star",
        "goldenArc"
      ],
      "priority": "maximum"
    },

    "level2": {
      "name": "Sistema Ornamental",
      "symbols": [
        "ornaments"
      ],
      "priority": "support"
    },

    "level3": {
      "name": "Sistema Estrutural",
      "symbols": [
        "frames"
      ],
      "priority": "support"
    },

    "level4": {
      "name": "Vocabulário Gráfico",
      "symbols": [
        "graphicElements"
      ],
      "priority": "complementary"
    }
  },

  "compositionRules": {
    "logoComposition": {
      "required": [
        "star",
        "goldenArc"
      ],

      "optional": [
        "ornaments",
        "graphicElements"
      ],

      "rules": [
        "A estrela deve ocupar posição hierárquica superior.",
        "O arco deve funcionar como elemento envolvente.",
        "Ornamentos não devem competir com o nome FESTANÇA.",
        "A composição deve permanecer legível em redução."
      ]
    },

    "heroComposition": {
      "preferred": [
        "star",
        "goldenArc",
        "ornaments"
      ],

      "maximumSymbolFamilies": 3
    },

    "historicalComposition": {
      "preferred": [
        "frames",
        "ornaments"
      ],

      "avoid": [
        "heavy-neon",
        "continuous-animation"
      ]
    },

    "ceremonialComposition": {
      "preferred": [
        "star",
        "goldenArc",
        "ornaments",
        "frames"
      ],

      "maximumDecorativeDensity": "rich-controlled"
    }
  },

  "safeAreas": {
    "star": {
      "minimum": "25%",
      "preferred": "35%"
    },

    "goldenArc": {
      "minimum": "15%",
      "preferred": "25%"
    },

    "ornaments": {
      "minimum": "10%"
    },

    "frames": {
      "innerMinimum": "8%",
      "innerPreferred": "12%",
      "outerMinimum": "8%"
    }
  },

  "colorUsage": {
    "primary": {
      "gold": {
        "preferredFor": [
          "star",
          "goldenArc",
          "ornaments",
          "frames"
        ]
      },

      "white": {
        "preferredFor": [
          "dark-backgrounds",
          "monochrome-layouts"
        ]
      },

      "black": {
        "preferredFor": [
          "light-backgrounds",
          "monochrome-print"
        ]
      }
    },

    "special": {
      "greenNeon": {
        "allowedFor": [
          "goldenArc",
          "graphicElements"
        ],
        "context": "digital-only"
      },

      "multicolor": {
        "allowed": false,
        "exception": "specific approved cultural composition"
      }
    }
  },

  "backgroundRules": {
    "dark": {
      "preferred": [
        "gold",
        "white",
        "neon-approved"
      ]
    },

    "light": {
      "preferred": [
        "gold",
        "black",
        "dark-monochrome"
      ]
    },

    "photographic": {
      "requirements": [
        "Maintain contrast.",
        "Apply protective field when necessary.",
        "Do not obscure faces or important cultural content."
      ]
    },

    "transparent": {
      "preferred": true
    }
  },

  "responsiveRules": {
    "mobile": {
      "maximumDecorativeFamilies": 2,
      "minimumStarSize": "24px",
      "simplifyOrnaments": true,
      "simplifyFrames": true
    },

    "tablet": {
      "maximumDecorativeFamilies": 3,
      "simplifyOrnaments": "optional"
    },

    "desktop": {
      "maximumDecorativeFamilies": 4
    },

    "largeDisplay": {
      "maximumDecorativeFamilies": 4,
      "monumentalEffectsAllowed": true
    }
  },

  "animationRules": {
    "star": {
      "allowed": [
        "fade",
        "slow-glow",
        "subtle-twinkle"
      ],

      "prohibited": [
        "rapid-flash",
        "spin",
        "bounce"
      ]
    },

    "goldenArc": {
      "allowed": [
        "stroke-reveal",
        "fade",
        "slow-glow"
      ],

      "prohibited": [
        "spin",
        "wave-distortion"
      ]
    },

    "ornaments": {
      "allowed": [
        "fade",
        "subtle-reveal"
      ]
    },

    "frames": {
      "allowed": [
        "fade",
        "line-reveal"
      ]
    },

    "reducedMotion": {
      "disableContinuous": true,
      "fallback": "static"
    }
  },

  "accessibility": {
    "principles": [
      "Símbolos decorativos devem ser ocultados de tecnologias assistivas.",
      "Símbolos informativos devem possuir nome acessível.",
      "Não depender exclusivamente do símbolo para transmitir informação essencial.",
      "Não utilizar efeitos que reduzam legibilidade.",
      "Não utilizar cintilação rápida.",
      "Preservar contraste suficiente.",
      "Não sobrepor símbolos a textos sem área de proteção."
    ],

    "decorativeMarkup": {
      "alt": "",
      "ariaHidden": true
    },

    "informativeMarkup": {
      "requireAlt": true
    }
  },

  "culturalSafeguards": {
    "principles": [
      "Respeito à dimensão religiosa e cultural.",
      "Preservação da identidade de Vila Bela da Santíssima Trindade.",
      "Não apropriação indevida.",
      "Não descaracterização de significados.",
      "Validação cultural para alterações substanciais."
    ],

    "prohibitedUses": [
      "Uso depreciativo.",
      "Uso jocoso de símbolos vinculados à fé.",
      "Associação com conteúdo discriminatório.",
      "Distorção intencional.",
      "Uso político-partidário sem autorização.",
      "Aplicação que sugira endosso institucional inexistente."
    ]
  },

  "printRules": {
    "minimumStroke": "0.5pt",

    "minimumSymbolSize": {
      "star": "8mm",
      "goldenArc": "35mm",
      "ornament": "6mm"
    },

    "recommendedFormats": [
      "SVG",
      "PDF",
      "high-resolution PNG"
    ],

    "rules": [
      "Evitar rasterização em baixa resolução.",
      "Verificar contraste na prova impressa.",
      "Preservar transparência.",
      "Não aplicar sombras excessivas em impressão simples."
    ]
  },

  "digitalRules": {
    "preferredFormats": [
      "SVG",
      "WebP",
      "PNG"
    ],

    "requirements": [
      "Otimizar peso.",
      "Utilizar lazy loading quando apropriado.",
      "Não ampliar raster acima da resolução original.",
      "Fornecer versão responsiva quando necessário."
    ]
  },

  "cssVariables": {
    "--festanca-symbol-star-size-sm": "24px",
    "--festanca-symbol-star-size-md": "64px",
    "--festanca-symbol-star-size-lg": "128px",

    "--festanca-symbol-safe-star": "25%",
    "--festanca-symbol-safe-arc": "15%",
    "--festanca-symbol-safe-ornament": "10%",

    "--festanca-symbol-opacity-muted": "0.68",
    "--festanca-symbol-opacity-decorative": "0.82",

    "--festanca-symbol-transition": "opacity 300ms cubic-bezier(0.2, 0, 0, 1), transform 300ms cubic-bezier(0.2, 0, 0, 1), filter 300ms cubic-bezier(0.2, 0, 0, 1)",

    "--festanca-symbol-glow-gold": "0 0 16px rgba(217, 162, 27, 0.42)",
    "--festanca-symbol-glow-gold-strong": "0 0 28px rgba(255, 211, 78, 0.60)"
  },

  "usageExamples": {
    "starDecorative": {
      "html": "<img src=\"assets/brand/symbols/estrela-festanca.png\" alt=\"\" aria-hidden=\"true\">"
    },

    "starInformative": {
      "html": "<img src=\"assets/brand/symbols/estrela-festanca.png\" alt=\"Estrela símbolo da FESTANÇA 2026\">"
    },

    "arcDecorative": {
      "html": "<img src=\"assets/brand/symbols/arco-dourado.png\" alt=\"\" aria-hidden=\"true\">"
    },

    "css": {
      "star": "filter: drop-shadow(var(--festanca-symbol-glow-gold));",
      "symbol": "transition: var(--festanca-symbol-transition);",
      "decorative": "opacity: var(--festanca-symbol-opacity-decorative);"
    }
  },

