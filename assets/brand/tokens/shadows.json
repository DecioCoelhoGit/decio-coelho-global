  "namingConvention": {
    "format": "shadow.{context}.{role}.{level}",
    "cssVariableFormat": "--festanca-shadow-{role}",
    "examples": [
      "shadow.elevation.level1",
      "shadow.component.card.default",
      "shadow.glow.gold.medium",
      "shadow.holographic.panel"
    ]
  },

  "principles": {
    "description": "Sombras, brilhos e efeitos de profundidade devem reforçar hierarquia, legibilidade e solenidade sem comprometer a autenticidade cultural.",

    "rules": [
      "Utilizar sombras para indicar profundidade e hierarquia.",
      "Evitar sombras excessivamente densas em textos.",
      "Reservar brilhos dourados para elementos de destaque.",
      "Utilizar efeitos neon apenas em ambientes digitais aprovados.",
      "Não aplicar brilho holográfico em documentos históricos formais.",
      "Manter foco visual acessível e claramente identificável.",
      "Utilizar efeitos cerimoniais com moderação.",
      "Evitar múltiplas sombras concorrentes no mesmo componente."
    ]
  },

