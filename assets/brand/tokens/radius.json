  "namingConvention": {
    "format": "radius.{context}.{role}.{size}",
    "cssVariableFormat": "--festanca-radius-{size}",
    "examples": [
      "radius.scale.md",
      "radius.component.card.default",
      "radius.component.button.pill",
      "radius.brand.ceremonial"
    ]
  },

  "principles": {
    "description": "Os arredondamentos devem equilibrar solenidade, acolhimento, acessibilidade e consistência visual.",

    "rules": [
      "Utilizar valores da escala oficial.",
      "Evitar arredondamentos arbitrários.",
      "Manter coerência entre componentes relacionados.",
      "Reservar formas circulares para avatares, ícones e indicadores.",
      "Utilizar formas cerimoniais com moderação.",
      "Preservar bordas mais discretas em documentos históricos.",
      "Não aplicar cantos excessivamente arredondados em tabelas densas."
    ]
  },

  "scale": {
    "none": {
      "value": "0",
      "pixels": 0,
      "type": "borderRadius",
      "description": "Sem arredondamento."
    },

    "2xs": {
      "value": "0.125rem",
      "pixels": 2,
      "type": "borderRadius",
      "description": "Arredondamento técnico mínimo."
    },

    "xs": {
      "value": "0.25rem",
