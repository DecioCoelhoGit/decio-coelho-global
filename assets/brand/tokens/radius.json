  "usageExamples": {
    "css": {
      "button": "border-radius: var(--festanca-radius-button);",
      "featureButton": "border-radius: var(--festanca-radius-button-prominent);",
      "card": "border-radius: var(--festanca-radius-card);",
      "featureCard": "border-radius: var(--festanca-radius-card-feature);",
      "input": "border-radius: var(--festanca-radius-input);",
      "modal": "border-radius: var(--festanca-radius-modal);",
      "avatar": "border-radius: var(--festanca-radius-circle);",
      "badge": "border-radius: var(--festanca-radius-pill);"
    },

    "componentMapping": {
      "primaryButton": "{component.button.default.value}",
      "culturalIcon": "{brand.iconContainer.cultural.value}",
      "programCard": "{component.card.default.value}",
      "historicalCard": "{component.card.historical.value}",
      "ceremonialCard": "{component.card.ceremonial.value}",
      "searchField": "{component.input.search.value}"
    }
  },

  "accessibility": {
    "rules": [
      "O arredondamento não deve reduzir a área útil de interação.",
      "Controles circulares devem manter área mínima de toque.",
      "Bordas arredondadas não devem cortar textos ou ícones.",
      "Estados de foco devem acompanhar corretamente o contorno.",
      "Elementos clicáveis semelhantes devem utilizar raios consistentes.",
      "Não utilizar formato circular em botões com textos extensos.",
      "Não depender do formato como único indicador de estado."
    ]
  },

  "restrictions": [
    "Não utilizar valores arbitrários quando existir token equivalente.",
    "Não misturar mais de três escalas de raio em um mesmo componente.",
    "Não utilizar formato circular em cards ou textos extensos.",
    "Não utilizar raio monumental em componentes compactos.",
    "Não remover o arredondamento de elementos interativos sem justificativa.",
    "Não aplicar arredondamentos que descaracterizem molduras históricas.",
    "Não cortar símbolos culturais com máscaras inadequadas.",
    "Toda alteração deverá ser registrada no CHANGELOG.md."
  ],

