{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "festanca-2026-field-observation-schema",
  "title": "FESTANÇA 2026 - Field Observation Schema",
  "description": "Estrutura oficial para registro de observações de campo da FESTANÇA 2026.",

  "version": "1.0.0",

  "metadata": {
