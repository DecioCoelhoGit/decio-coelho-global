    "collectionMethods": [

      "direct-observation",

      "participant-report",

      "organization",

      "official-document",

      "photographic-record",

      "audio-record",

      "video-record"
    ],

    "validationStatus": [

      "pending",

      "confirmed",

      "partially-confirmed",

      "rejected"
    ],

