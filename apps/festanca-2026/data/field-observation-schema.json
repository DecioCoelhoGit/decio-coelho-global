    "activityId": null,

    "activityName": null,

    "observationType": null,

    "collectionMethod": null,

    "timestamp": null,

    "observer": {
      "name": null,
      "organization": null,
      "contact": null
    },

    "source": {
      "type": null,
      "name": null,
      "confidence": "medium"
    },

    "location": {

      "locationType": null,

      "publicMap": false,

      "protectedResidence": false,

      "description": null,

      "coordinates": null
    },

    "participants": {

      "groups": [],

      "authorities": [],

      "festeiros": [],

      "community": []
    },

    "media": {

      "photos": [],

      "videos": [],

      "audio": [],

      "documents": []
    },

    "fieldNotes": {

      "summary": null,

      "detailedDescription": null,

      "importantFacts": [],

      "changesFromOfficialProgram": [],

      "visitorRecommendations": []
    },

    "validation": {

      "status": "pending",

      "validatedBy": null,

      "validationDate": null,

      "notes": null
    },

    "publication": {

      "canPublish": false,

      "requiresReview": true,

      "privacyLevel": "protected"
    },

    "tags": [],

    "history": []
